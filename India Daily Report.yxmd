        <Node ToolID="160">
          <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
            <Position x="114" y="210" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Passwords />
              <File />
              <FormatSpecificOptions UseDcm="true" Format="23" RecordLimit="">
                <Query>SELECT
    "CMPT052_RLSE_REQ"."CD_PLANT",
    "CMPT052_RLSE_REQ"."CD_CUSTOMER",
    "CPNT023_PART"."NO_COMP_PART_NO",
    "CRCT002_ASN_PART"."CD_SHIP_FROM",
    "CUCT001_COMP_LOC"."NA_COMP",
    "CUCT001_COMP_LOC"."NA_STREET",
    "CRCT002_ASN_PART"."NO_PACKING_SLIP",
    "CRCT002_ASN_PART"."QT_RECEIVED_ASN",
    "CRCT001_ASN"."DT_SHIPPED",
    "CRCT004_CONVYNCE"."DT_EXPECTED_ARRVL",
    "CMPT052_RLSE_REQ"."QT_RLSE_REQ_1",
    "CMPT052_RLSE_REQ"."QT_RLSE_REQ_2",
    "CMPT052_RLSE_REQ"."QT_RLSE_REQ_3",
    "CMPT052_RLSE_REQ"."QT_RLSE_REQ_4",
    "CMPT097_PART_CUST"."QT_CUM_SHIPPED",
    "CPNT023_PART"."QT_PRT_BOH_LOOSE",
    "CRCT004_CONVYNCE"."CD_CONVEYANCE_STAT",
    "CMPT052_RLSE_REQ"."DT_RELEASE",
    "CMPT052_RLSE_REQ"."NO_RELEASE"
FROM "MMDBDP7"."CRCT004_CONVYNCE"
INNER JOIN (
    "MMDBDP7"."CRCT001_ASN"
    INNER JOIN (
        "MMDBDP7"."CRCT002_ASN_PART"
        INNER JOIN (
            "MMDBDP7"."CMPT052_RLSE_REQ"
            LEFT JOIN "MMDBDP7"."CPNT023_PART"
                ON "CMPT052_RLSE_REQ"."CD_PLANT" = "CPNT023_PART"."CD_PLANT"
                AND "CMPT052_RLSE_REQ"."NO_PART_BASE" = "CPNT023_PART"."NO_PART_BASE"
                AND "CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "CPNT023_PART"."NO_PART_PREFIX"
                AND "CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "CPNT023_PART"."NO_PART_SUFFIX"
            INNER JOIN "MMDBDP7"."CMPT097_PART_CUST"
                ON "CMPT052_RLSE_REQ"."CD_PLANT" = "CMPT097_PART_CUST"."CD_PLANT"
                AND "CMPT052_RLSE_REQ"."NO_PART_BASE" = "CMPT097_PART_CUST"."NO_PART_BASE"
                AND "CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "CMPT097_PART_CUST"."NO_PART_PREFIX"
                AND "CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "CMPT097_PART_CUST"."NO_PART_SUFFIX"
                AND "CMPT052_RLSE_REQ"."NO_PART_CONTROL" = "CMPT097_PART_CUST"."NO_PART_CONTROL"
        ) ON "CMPT052_RLSE_REQ"."CD_PLANT" = "CRCT002_ASN_PART"."CD_PLANT"
            AND "CMPT052_RLSE_REQ"."NO_PART_BASE" = "CRCT002_ASN_PART"."NO_PART_BASE"
            AND "CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "CRCT002_ASN_PART"."NO_PART_PREFIX"
            AND "CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "CRCT002_ASN_PART"."NO_PART_SUFFIX"
            AND "CMPT052_RLSE_REQ"."NO_PART_CONTROL" = "CRCT002_ASN_PART"."NO_PART_CONTROL"
    ) ON "CRCT002_ASN_PART"."NO_ASN" = "CRCT001_ASN"."NO_ASN"
        AND "CRCT002_ASN_PART"."CD_SHIP_FROM" = "CRCT001_ASN"."CD_SHIP_FROM"
        AND "CRCT002_ASN_PART"."NO_CONVEYANCE" = "CRCT001_ASN"."NO_CONVEYANCE"
        AND "CRCT002_ASN_PART"."CD_PLANT" = "CRCT001_ASN"."CD_PLANT"
) ON "CRCT004_CONVYNCE"."CD_DUP_CONVEYANCE" = "CRCT001_ASN"."CD_DUP_CONVEYANCE"
    AND "CRCT004_CONVYNCE"."NO_CONVEYANCE" = "CRCT001_ASN"."NO_CONVEYANCE"
    AND "CRCT004_CONVYNCE"."CD_PLANT" = "CRCT001_ASN"."CD_PLANT"
INNER JOIN "MMDBDP7"."CUCT001_COMP_LOC"
    ON "CRCT002_ASN_PART"."CD_SHIP_FROM" = "CUCT001_COMP_LOC"."CD_COMP_LOC"
WHERE (
    ("CMPT052_RLSE_REQ"."CD_PLANT" LIKE '1688%' 
     OR "CMPT052_RLSE_REQ"."CD_PLANT" LIKE 'HQHN%' 
     OR "CMPT052_RLSE_REQ"."CD_PLANT" = '1055P')
    AND "CMPT052_RLSE_REQ"."CD_CUSTOMER" &lt;&gt; "CRCT002_ASN_PART"."CD_SHIP_FROM"
    AND "CRCT004_CONVYNCE"."CD_CONVEYANCE_STAT" = 'I'
    AND "CMPT052_RLSE_REQ"."DT_RELEASE" = TRUNC(SYSDATE, 'IW')
);</Query>
