      <ChildNodes>
        <Node ToolID="115">
          <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
            <Position x="3186" y="139" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Passwords />
              <File />
              <FormatSpecificOptions UseDcm="true" Format="23" RecordLimit="">
                <Query>SELECT
    "MMDBDP7"."CMPT097_PART_CUST"."CD_PLANT",
    "MMDBDP7"."CPNT023_PART"."NO_COMP_PART_NO",
    "MMDBDP7"."CSFT040_PROD_LBL"."NO_LABEL_SERIAL",
    "MMDBDP7"."CSFT040_PROD_LBL"."QT_PART_PROD",
    "MMDBDP7"."CSFT040_PROD_LBL"."CD_LABEL_STATUS",
    "MMDBDP7"."CMPT097_PART_CUST"."CD_CUSTOMER",
    "MMDBDP7"."CSFT040_PROD_LBL"."TS_LAST_UPDATE",
    "MMDBDP7"."CSFT040_PROD_LBL"."DT_LABEL_PRODUCED"
FROM "MMDBDP7"."CMPT097_PART_CUST"
INNER JOIN "MMDBDP7"."CPNT023_PART"
    ON "MMDBDP7"."CMPT097_PART_CUST"."CD_PLANT"        = "MMDBDP7"."CPNT023_PART"."CD_PLANT"
   AND "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_BASE"    = "MMDBDP7"."CPNT023_PART"."NO_PART_BASE"
   AND "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_PREFIX"  = "MMDBDP7"."CPNT023_PART"."NO_PART_PREFIX"
   AND "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_SUFFIX"  = "MMDBDP7"."CPNT023_PART"."NO_PART_SUFFIX"
   AND "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_CONTROL" = "MMDBDP7"."CPNT023_PART"."NO_PART_CONTROL"
INNER JOIN "MMDBDP7"."CSFT040_PROD_LBL"
    ON "MMDBDP7"."CPNT023_PART"."CD_PLANT"        = "MMDBDP7"."CSFT040_PROD_LBL"."CD_PLANT"
   AND "MMDBDP7"."CPNT023_PART"."NO_PART_BASE"    = "MMDBDP7"."CSFT040_PROD_LBL"."NO_PART_BASE"
   AND "MMDBDP7"."CPNT023_PART"."NO_PART_PREFIX"  = "MMDBDP7"."CSFT040_PROD_LBL"."NO_PART_PREFIX"
   AND "MMDBDP7"."CPNT023_PART"."NO_PART_SUFFIX"  = "MMDBDP7"."CSFT040_PROD_LBL"."NO_PART_SUFFIX"
