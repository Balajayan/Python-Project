                <FormulaField expression="IF ToNumber([BGHA Shortage]) &lt; 0 &#xA;THEN &#xA;    IF  ToNumber([QT_PRT_BOH_LOOSE]) &gt;0 and (ToNumber([QT_PRT_BOH_LOOSE]) &lt; - ToNumber([BGHA Shortage])  )&#xA;    THEN &#xA;        1&#xA;    ELSE &#xA;        &quot;&quot;&#xA;    ENDIF&#xA;ELSE &#xA;    &quot;&quot;&#xA;ENDIF" field="Rise Partial Qty Avbl at EDC" size="1073741823" type="V_WString" enabled="true" />
