                <FormulaField expression="IF ToNumber([BGHA Shortage]) &lt; 0 &#xA;THEN&#xA;    IF ToNumber([Rlse Full Qty Avbl at EDC]) = 1 &#xA;    THEN&#xA;        &quot;&quot;&#xA;    ELSE&#xA;        IF (ToNumber([QT_PRT_BOH_LOOSE]) + ToNumber([QT_SUPP_IN_TRANSIT])) &gt;= -ToNumber([BGHA Shortage])&#xA;        THEN&#xA;            &quot;&quot;&#xA;        ELSE&#xA;            1&#xA;        ENDIF&#xA;    ENDIF&#xA;ELSE &#xA;    &quot;&quot;&#xA;ENDIF" field="Rise Yet to be Shipped by Supplier" size="1073741823" type="V_WString" enabled="true" />
