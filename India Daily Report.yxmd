        <Node ToolID="103">
          <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
            <Position x="1413" y="141" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Passwords />
              <File />
              <FormatSpecificOptions UseDcm="true" Format="23" RecordLimit="">
                <Query>SELECT
    "MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT",
    "MMDBDP7"."CPNT023_PART"."NO_COMP_PART_NO",
    "MMDBDP7"."CPNT029_PART_SUPP"."CD_SUPPLIER_SHP_FR",
    "MMDBDP7"."CUCT001_COMP_LOC"."NA_COMP",
    "MMDBDP7"."CUCT001_COMP_LOC"."NA_STREET",
    "MMDBDP7"."CUCT001_COMP_LOC"."NA_CITY",
    "MMDBDP7"."CUCT001_COMP_LOC"."NA_COUNTY",
    "MMDBDP7"."CMPT052_RLSE_REQ"."CD_CUSTOMER",
    "MMDBDP7"."CMPT052_RLSE_REQ"."QT_RLSE_REQ_1",
    "MMDBDP7"."CMPT097_PART_CUST"."QT_CUM_SHIPPED",
    "MMDBDP7"."CPNT023_PART"."QT_PRT_BOH_LOOSE",
    "MMDBDP7"."CPNT029_PART_SUPP"."QT_SUPP_IN_TRANSIT",
    "MMDBDP7"."CMPT052_RLSE_REQ"."NO_RELEASE",
    "MMDBDP7"."CMPT097_PART_CUST"."QT_PR_DAY_CUM_SHP",
    "MMDBDP7"."CPNT023_PART"."CD_PART_STATUS",
    "MMDBDP7"."CMST045_PCT_BUS"."PC_BUSINESS",
    "MMDBDP7"."CMST045_PCT_BUS"."DT_EFF",
    "MMDBDP7"."CMPT052_RLSE_REQ"."DT_RELEASE" 
FROM "MMDBDP7"."CMPT052_RLSE_REQ" 
    INNER JOIN "MMDBDP7"."CMPT097_PART_CUST" 
        ON "MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" = "MMDBDP7"."CMPT097_PART_CUST"."CD_PLANT" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_BASE" = "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_BASE" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_PREFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "MMDBDP7"."CMPT097_PART_CUST"."NO_PART_SUFFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."CD_CUSTOMER" = "MMDBDP7"."CMPT097_PART_CUST"."CD_CUSTOMER" 
    INNER JOIN "MMDBDP7"."CPNT023_PART" 
        ON "MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" = "MMDBDP7"."CPNT023_PART"."CD_PLANT" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_BASE" = "MMDBDP7"."CPNT023_PART"."NO_PART_BASE" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "MMDBDP7"."CPNT023_PART"."NO_PART_PREFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "MMDBDP7"."CPNT023_PART"."NO_PART_SUFFIX" 
    INNER JOIN "MMDBDP7"."CPNT029_PART_SUPP" 
        ON "MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" = "MMDBDP7"."CPNT029_PART_SUPP"."CD_PLANT" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_BASE" = "MMDBDP7"."CPNT029_PART_SUPP"."NO_PART_BASE" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "MMDBDP7"."CPNT029_PART_SUPP"."NO_PART_PREFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "MMDBDP7"."CPNT029_PART_SUPP"."NO_PART_SUFFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_CONTROL" = "MMDBDP7"."CPNT029_PART_SUPP"."NO_PART_CONTROL" 
    INNER JOIN "MMDBDP7"."CUCT001_COMP_LOC" 
        ON "MMDBDP7"."CPNT029_PART_SUPP"."CD_SUPPLIER_SHP_FR" = "MMDBDP7"."CUCT001_COMP_LOC"."CD_COMP_LOC" 
    INNER JOIN "MMDBDP7"."CMST045_PCT_BUS" 
        ON "MMDBDP7"."CPNT029_PART_SUPP"."CD_SUPPLIER_SHP_FR" = "MMDBDP7"."CMST045_PCT_BUS"."CD_SUPPLIER_SHP_FR" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" = "MMDBDP7"."CMST045_PCT_BUS"."CD_PLANT" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_BASE" = "MMDBDP7"."CMST045_PCT_BUS"."NO_PART_BASE" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_PREFIX" = "MMDBDP7"."CMST045_PCT_BUS"."NO_PART_PREFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_SUFFIX" = "MMDBDP7"."CMST045_PCT_BUS"."NO_PART_SUFFIX" 
        AND "MMDBDP7"."CMPT052_RLSE_REQ"."NO_PART_CONTROL" = "MMDBDP7"."CMST045_PCT_BUS"."NO_PART_CONTROL" 
WHERE 
 (
  ("MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" Like '1688%') 
	or ("MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" Like 'HQHN%') 
	or ("MMDBDP7"."CMPT052_RLSE_REQ"."CD_PLANT" = '1055P')
	)
    AND "MMDBDP7"."CPNT023_PART"."CD_PART_STATUS" &lt;&gt; 'D'
    AND "MMDBDP7"."CMST045_PCT_BUS"."PC_BUSINESS" &lt;&gt; 0
    AND "MMDBDP7"."CMPT052_RLSE_REQ"."DT_RELEASE" = TRUNC(SYSDATE, 'IW');</Query>
